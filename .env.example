# MySQL
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=jejuday
MYSQL_USER=jejuday
MYSQL_PASSWORD=change-me

# Spring datasource (docker profile uses these)
DATABASE_USER=jejuday
DATABASE_PASSWORD=change-me

# JWT (최소 256비트 랜덤 문자열)
JWT_SECRET=your-jwt-secret-key-here-minimum-256-bits

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=ap-northeast-2

# Kakao OAuth
KAKAO_ID=your-kakao-client-id
KAKAO_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URL=http://localhost:8080/auth/kakao/callback

# Mail (Gmail 앱 비밀번호)
SPRING_MAIL_PASSWORD=your-gmail-app-password

# Tour API
TOUR_API_KEY=your-tour-api-key
